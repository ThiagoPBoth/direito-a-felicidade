<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="15dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">


    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/rvArtigos"
        android:scrollbars="vertical"

        app:cardUseCompatPadding="true"
       android:elevation="10dp"
        app:cardCornerRadius="30dp"

        >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFF0D5"

            android:orientation="vertical"

            android:padding="15dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Título: "
                android:textColor="#000000"
                android:textSize="20dp"
                android:textStyle="bold"></TextView>

            <TextView
                android:id="@+id/tvNomeArtigo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"

                android:layout_marginBottom="40px"
                android:text="Nome:"
                android:textSize="24sp"

                />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Autor: "
                android:textColor="#000000"
                android:textSize="20dp"
                android:textStyle="bold"></TextView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/tvAutorArtigo"
                android:text="Escritor: "

                android:textSize="24sp"
                android:layout_marginBottom="40px"
                />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ano do artigo: "
                android:textColor="#000000"
                android:textSize="20dp"
                android:textStyle="bold"></TextView>


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/tvAnoArtigo"
                android:text="Ano: "

                android:textSize="24sp"
                android:layout_marginBottom="40px"
                />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Temática(s): "
                android:textColor="#000000"
                android:textSize="20dp"
                android:textStyle="bold"></TextView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/tvTematicasArtigo"
                android:text="Tematicas: "

                android:textSize="24sp"
                />

            <Button
                android:layout_width="200dp"
                android:layout_height="60dp"
                android:text="Acessar"
                android:layout_gravity="center"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp">

            </Button>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>