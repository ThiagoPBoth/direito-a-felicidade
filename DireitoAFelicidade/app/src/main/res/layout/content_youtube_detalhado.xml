<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="15dp"
    app:layout_behavior="@string/appbar_scrolling_view_behavior"
    tools:context=".YoutubeDetalhadoActivity"
    tools:showIn="@layout/activity_youtube_detalhado">


    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/ivDetalhadoCapaCanal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:contentDescription="@null"
                android:src="@mipmap/ic_launcher" />


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nome do canal: "
                android:textColor="#000000"
                android:textSize="20dp"
                android:textStyle="bold"></TextView>

    <TextView
        android:id="@+id/tvDetalhadoNomeCanal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:layout_marginBottom="40px"
        android:text="Nome do Canal"
        android:textSize="20dp"></TextView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Descrição: "
                android:textColor="#000000"
                android:textSize="20dp"
                android:textStyle="bold"></TextView>

    <TextView
        android:id="@+id/tvDetalhadoDescricaoCanal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:layout_marginBottom="40px"
        android:text="Descrição"

        android:textSize="20dp" />


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Indicado para: "
                android:textColor="#000000"
                android:textSize="20dp"
                android:textStyle="bold"></TextView>

    <TextView
        android:id="@+id/tvDetalhadoIndicacaoCanal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:layout_marginBottom="40px"
        android:text="Indicação"

        android:textSize="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Temática(s): "
                android:textColor="#000000"
                android:textSize="20dp"
                android:textStyle="bold"></TextView>

    <TextView
        android:id="@+id/tvDetalhadoTematicaCanal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:layout_marginBottom="40px"
        android:text="Tematica do Canal"

        android:textSize="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Link: "
                android:textColor="#000000"
                android:textSize="20dp"
                android:textStyle="bold"></TextView>

    <TextView
        android:id="@+id/tvDetalhadoLinkCanal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:layout_marginBottom="40px"
        android:text="Link do Canal"

        android:textSize="20dp" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>